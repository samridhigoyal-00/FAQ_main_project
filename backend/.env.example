# MongoDB connection URI (Cloud Atlas or Local)
MONGO_URI=your_mongodb_connection_string_here

# Google OAuth 2.0 Client Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Signature Verification Secret Key
JWT_SECRET=your_custom_jwt_secret_key_here

# Backend Server Listening Port
PORT=5000

# Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Frontend URL(s) for CORS (comma-separated)
CLIENT_URL=http://localhost:3000

# Max AI messages per student per day
AI_DAILY_LIMIT=40
